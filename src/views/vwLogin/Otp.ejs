<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .otp-container {
            max-width: 400px;
            margin: 50px auto;
            padding: 20px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            border-radius: 8px;
        }
    </style>
</head>
<body class="bg-light">
    <div class="container">
        <div class="otp-container bg-white">
            <h2 class="text-center mb-4">OTP Verification</h2>

            <% if (!otpSent) { %>
            <!-- Email Form -->
            <div class="mb-3">
                <label for="email" class="form-label">Email address</label>
                <input type="email" class="form-control" id="email" name="email" required>
            </div>
            <button type="button" class="btn btn-primary w-100" onclick="requestOTP()">Get OTP</button>
            <% } else { %>
            <!-- OTP Form -->
            <div class="mb-3">
                <label for="otp" class="form-label">Enter OTP</label>
                <input type="text" class="form-control" id="otp" maxlength="6" required>
                <div class="form-text">
                    Enter the 6-digit code sent to <%= email %>
                </div>
            </div>
            <button type="button" class="btn btn-primary w-100 mb-2" onclick="verifyOTP()">Verify OTP</button>
            <button type="button" class="btn btn-outline-secondary w-100" onclick="resendOTP()">Resend OTP</button>
            <% } %>

            <% if (error) { %>
            <div class="alert alert-danger mt-3" role="alert">
                <%= error %>
            </div>
            <% } %>

            <% if (success) { %>
            <div class="alert alert-success mt-3" role="alert">
                <%= success %>
            </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function requestOTP() {
            const email = document.getElementById('email').value;
            if (!email) {
                showError('Email is required');
                return;
            }

            fetch('/OTP', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.reload();
                } else {
                    showError(data.error);
                }
            })
            .catch(error => {
                showError('Failed to send OTP. Please try again.');
            });
        }

        function verifyOTP() {
            const otp = document.getElementById('otp').value;
            const email = '<%= email %>';

            fetch('/OTP/verify', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email, otp })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showSuccess('OTP verified successfully!');
                    setTimeout(() => {
                        window.location.href = '/dashboard';
                    }, 1000);
                } else {
                    showError(data.error);
                }
            })
            .catch(error => {
                showError('Verification failed. Please try again.');
            });
        }

        function resendOTP() {
            const email = '<%= email %>';
            fetch('/OTP/generate', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showSuccess('New OTP sent successfully!');
                } else {
                    showError(data.error);
                }
            })
            .catch(error => {
                showError('Failed to resend OTP. Please try again.');
            });
        }

        function showError(message) {
            const alertDiv = document.createElement('div');
            alertDiv.className = 'alert alert-danger mt-3';
            alertDiv.role = 'alert';
            alertDiv.textContent = message;
            document.querySelector('.otp-container').appendChild(alertDiv);
            setTimeout(() => alertDiv.remove(), 5000);
        }

        function showSuccess(message) {
            const alertDiv = document.createElement('div');
            alertDiv.className = 'alert alert-success mt-3';
            alertDiv.role = 'alert';
            alertDiv.textContent = message;
            document.querySelector('.otp-container').appendChild(alertDiv);
            setTimeout(() => alertDiv.remove(), 5000);
        }
    </script>
</body>
</html>